rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() { return request.auth != null; }
    function isAdmin() {
      return request.auth != null && request.auth.token.role == 'admin';
    }

    // Public therapist assets (photos). Owner writes.
    match /therapists/{uid}/{allPaths=**} {
      allow read:  if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Per-user assets (legacy path; prefer avatars/ for profile photos).
    match /users/{uid}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Profile avatars — public read, owner write, images only, ≤ 1 MB.
    match /avatars/{uid}/{allPaths=**} {
      allow read:  if true;
      allow write: if request.auth != null && request.auth.uid == uid
                   && request.resource.size < 1 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Therapist application documents (CV) — PDF only.
    match /applications/{uid}/{allPaths=**} {
      allow read:  if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow write: if request.auth != null && request.auth.uid == uid
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType == 'application/pdf';
    }

    // Payment proofs (InstaPay screenshots) — writable by owner, readable by owner + admin.
    match /payments/{uid}/{allPaths=**} {
      allow read:  if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow write: if request.auth != null && request.auth.uid == uid
                   && request.resource.size < 8 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*|application/pdf');
    }

    // Report attachments (scoped by session) — therapist + patient.
    match /reports/{sessionId}/{allPaths=**} {
      allow read:  if isSignedIn();
      allow write: if isSignedIn();
    }

    // Article cover images — admin writes, public reads.
    match /articles/{allPaths=**} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
